# ==========================================================
# FINAL PCA PLOT - LABELS + PERFECT AXES
# ==========================================================

library(ggrepel)  # 👈 Add this if not loaded

# 1. VST transform
vsd <- vst(dds, blind = FALSE)

# 2. PCA data
pcaData <- plotPCA(vsd, intgroup = "group", returnData = TRUE)
percentVar <- round(100 * attr(pcaData, "percentVar"))

# 🔍 Ranges
cat("📊 PC1:", round(range(pcaData$PC1), 2), " | PC2:", round(range(pcaData$PC2), 2), "\n")
cat("📈 Variance: PC1 =", percentVar[1], "% | PC2 =", percentVar[2], "%\n\n")

# 3. FINAL PLOT
pca_plot <- ggplot(pcaData, aes(PC1, PC2, color = group)) +
  
  # 🔹 Grey dotted reference axes at 0
  geom_hline(yintercept = 0, linetype = "dotted", color = "grey50", size = 0.8) +
  geom_vline(xintercept = 0, linetype = "dotted", color = "grey50", size = 0.8) +
  
  # Points
  geom_point(size = 5, alpha = 0.9, stroke = 0.8) +
  
  # Labels
  geom_text_repel(aes(label = rownames(pcaData)), 
                  size = 4, fontface = "bold", 
                  box.padding = 0.3, point.padding = 0.3,
                  max.overlaps = Inf) +
  
  labs(
    x = paste0("PC1 (", percentVar[1], "%)"),
    y = paste0("PC2 (", percentVar[2], "%)")
  ) +
  
  coord_fixed(
    ratio = 1,
    xlim = c(-4,4),
    ylim = c(-3,3)
  ) +
  
  scale_color_manual(
    values = c("TNTCN" = "#D7301F", "3NT" = "#7D26CD"),
    labels = c("TNT" = "TNTCN", "3NT" = "3NT"),
    name = NULL
    
  ) +
  
  # 🔥 BOXED CLEAN THEME (no grid, with border)
  theme_bw(base_size = 15) +
  theme(
    legend.position = "top",
    panel.grid = element_blank(),        
    panel.border = element_rect(color = "black", size = 1),  # ✅
    axis.title = element_text(size = 13, face = "bold")
  )
# 4. Display & save
print(pca_plot)
ggsave(file.path(output_dir, "PCA_TNTCN_vs_3NT_final.png"), 
       pca_plot, width = 11, height = 8, dpi = 300, bg = "white")

cat("✅ PCA plot saved: PCA_TNT_vs_TNTN_final.png\n")
cat("📐 Axes: X=[-8,12] | Y=[-3.5,2.5]\n")
cat("🏷️  Labels: TNTN1,TNTN2,TNTN3,TNT1,TNT2,TNT3\n")




