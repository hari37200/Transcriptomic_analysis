# Optional but VERY useful
targets$sample_id <- c(
  "CN1","CN2","CN3",
  "TNTN1","TNTN2","TNTN3",
  "TNTCN1","TNTCN2","TNTCN3",
  "TNTC1","TNTC2","TNTC3",
  "TNT1","TNT2","TNT3",
  "L3NT1","L3NT2","L3NT3"
)
# ----------------------------------------------------------
# Load FeatureCounts tables
# ----------------------------------------------------------
count_list <- lapply(as.character(targets$files), function(f) {
  dat <- read.delim(f, header = FALSE, comment.char = "#")
  colnames(dat) <- c("Geneid","Chr","Start","End","Strand","Length","Counts")
  dat <- dat[, c("Geneid","Counts")]
  colnames(dat)[2] <- basename(f)
  dat
})

countData <- Reduce(function(x,y) merge(x,y,by="Geneid",all=TRUE), count_list)

rownames(countData) <- countData$Geneid
countData <- countData[, -1]

countData[] <- lapply(countData, function(x) suppressWarnings(as.numeric(as.character(x))))
countData[is.na(countData)] <- 0
countData <- countData[rowSums(countData) > 0, ]
# Ensure correct column order FIRST
countData <- countData[, basename(targets$files)]

# THEN optionally rename
colnames(countData) <- targets$sample_id


# ----------------------------------------------------------
# DESeq2 object
# ----------------------------------------------------------
dds <- DESeqDataSetFromMatrix(
  countData = round(as.matrix(countData)),
  colData = targets,
  design = ~ group
)
# Keep TNTC and CN only
dds <- dds[, dds$group %in% c("TNT","TNTN")]
dds$group <- droplevels(dds$group)

# Set reference = L3NT
dds$group <- relevel(dds$group, ref = "TNTN")

# 1. Sample verification
print("Samples selected:")
print(table(dds$group))
print(colnames(dds))  # Verify column names match

# 2.Count quality
print("Total counts per sample:")
print(round(colSums(counts(dds))))

# RUN DESEQ 
dds <- DESeq(dds)


# ----------------------------------------------------------
# Get results
# ----------------------------------------------------------
res <- results(dds, contrast = c("group", "TNT", "TNTN"))
res <- lfcShrink(dds, contrast=c("group","TNT","TNTN"), res=res, type="ashr")
res <- res[order(res$padj), ]

# Save complete results
write.csv(as.data.frame(res),
          file=file.path(output_dir,"DESeq2_TNT_vs_TNTN_all.csv"))

# ----------------------------------------------------------
# Significant genes
# ----------------------------------------------------------
sig <- subset(res, padj < 0.05 & abs(log2FoldChange) > 0)

write.csv(sig,
          file=file.path(output_dir,"DESeq2_TNTN_vs_3NT_sig.csv"))



