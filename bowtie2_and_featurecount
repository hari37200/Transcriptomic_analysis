#!/bin/bash

IN_DIR="/mnt/e/RNA_QC_DS2/ANALYSIS/deduplicate_Sam"
OUT_DIR="/mnt/e/RNA_QC_DS2/ANALYSIS/FEATURECOUNT"
ANNOTATION="/mnt/d/research/DS2_rw.gff3"
THREADS=12

mkdir -p "$OUT_DIR"

# Extract all unique feature types from GFF3
FEATURES=$(awk '$1 !~ /^#/ {print $3}' "$ANNOTATION" | sort | uniq)

for BAM in "$IN_DIR"/*_dedup.bam; do
    SAMPLE=$(basename "$BAM" _dedup.bam)
    echo "📊 Counting features for $SAMPLE ..."

    for FEATURE in $FEATURES; do
        echo "   Counting $FEATURE ..."
        featureCounts -p -O -T $THREADS \
          -a $ANNOTATION -F GFF \
          -t $FEATURE \
          -g ID \
          -o "$OUT_DIR/${SAMPLE}_${FEATURE}_featureCounts.txt" \
          "$BAM"
    done

    echo "✅ Done: $SAMPLE"
done
